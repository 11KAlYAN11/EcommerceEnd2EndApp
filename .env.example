# Copy this file to .env and fill real values
# .env is gitignored — never commit secrets
#
# On EC2, the full production version of this file lives at /home/ec2-user/shopease.env
# and is passed to the container via: docker run --env-file /home/ec2-user/shopease.env
# If the EC2 is ever rebuilt, recreate that file from this template.

# ── Database (prod: RDS endpoint) ─────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/ecommerce
DB_USERNAME=postgres
DB_PASSWORD=root

# ── Redis (prod: ElastiCache endpoint) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT — generate with: openssl rand -hex 64 ─────────────────────
JWT_SECRET=ecommerce-super-secret-key-change-in-production-must-be-at-least-256-bits

# ── Email (Gmail App Password — not your account password) ────────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── CORS — comma separated frontend origins (prod: CloudFront URL) ─
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Seed admin (prod: set real credentials, defaults are test-only) ─
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_FIRSTNAME=Admin
SEED_ADMIN_LASTNAME=ShopEase

# ── Rate limiting ──────────────────────────────────────────────────
# RATELIMIT_ENABLED=false ONLY for load testing — never leave off in prod
RATELIMIT_ENABLED=true
RATELIMIT_MAX_REQUESTS=100
RATELIMIT_WINDOW_MS=60000

# ── Grafana (monitoring stack, see monitoring/ dir) ───────────────
GRAFANA_PASSWORD=admin
